{
    "console": {
        "enable": true,
        "level": "FINE"
    },

    "files": [
        {
            "enable": true,
            "level": "DEBUG",
            "filename": "logs/devtv.log",
            "category": "default",
            "pattern": "[%D %T] [%C] [%L] (%S) %M",
            "rotate": true,
            "maxsize": "500M",
            "maxlines": "10K",
            "daily": true,
            "santize": true
        }
    ],

    "sockets": [
        {
            "enable": false,
            "level": "DEBUG",
            "category": "TestSocket",
            "pattern": "[%D %T] [%C] [%L] (%S) %M",
            "addr": "127.0.0.1:12124",
            "protocol": "udp"
        }
    ]
}
